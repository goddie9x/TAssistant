<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0F0F0F">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TAssistant" android:textSize="32sp" android:textColor="#00E676" android:layout_gravity="center" android:fontFamily="sans-serif-black" android:layout_marginTop="10dp"/>
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="20dp">
            <Button android:id="@+id/btnPermMic" android:layout_width="match_parent" android:layout_height="50dp" android:text="MIC: PENDING" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:layout_marginBottom="6dp" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnPermOverlay" android:layout_width="match_parent" android:layout_height="50dp" android:text="OVERLAY: PENDING" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:layout_marginBottom="6dp" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnPermAccessibility" android:layout_width="match_parent" android:layout_height="50dp" android:text="ACCESSIBILITY: PENDING" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:layout_marginBottom="6dp" app:cornerRadius="10dp"/>
            <Button android:id="@+id/btnPermWriteSettings" android:layout_width="match_parent" android:layout_height="50dp" android:text="SYSTEM WRITE: PENDING" android:backgroundTint="#222222" android:textColor="#FFFFFF" app:cornerRadius="10dp"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" app:cardBackgroundColor="#1A1A1A" android:layout_marginTop="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <EditText android:id="@+id/etApiKey" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Mistral API Key" android:textColor="#FFFFFF" android:backgroundTint="#00E676" android:inputType="textPassword" android:textColorHint="#444444"/>
                <EditText android:id="@+id/etWakeWord" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Wake Word" android:textColor="#FFFFFF" android:backgroundTint="#00E676" android:textColorHint="#444444"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout android:id="@+id/categoryContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="20dp"/>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="15dp" app:cardBackgroundColor="#1A1A1A" android:layout_marginTop="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CUSTOM APP COMMANDS" android:textColor="#00E676" android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
                <LinearLayout android:id="@+id/customAppContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
                <Button android:id="@+id/btnAddCustomApp" android:layout_width="match_parent" android:layout_height="40dp" android:text="+ ADD NEW COMMAND" android:backgroundTint="#222222" android:textColor="#00E676" app:cornerRadius="8dp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="60dp" android:text="SAVE ALL" android:backgroundTint="#00E676" android:textColor="#000000" android:textStyle="bold" android:layout_marginTop="24dp" app:cornerRadius="12dp"/>
        <Button android:id="@+id/btnTestVoice" android:layout_width="match_parent" android:layout_height="50dp" android:text="WAKE TEST" android:backgroundTint="#1A1A1A" android:textColor="#00E676" app:cornerRadius="12dp" app:strokeWidth="1dp" app:strokeColor="#00E676" android:layout_marginTop="10dp" android:layout_marginBottom="30dp"/>
    </LinearLayout>
</ScrollView>